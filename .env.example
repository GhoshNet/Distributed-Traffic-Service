# ============================================================
# Journey Booking System — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values if you want
# to override the defaults used by docker-compose.yml and
# run_local.sh.
#
# In practice, for the Docker setup the values in
# docker-compose.yml are used directly and work out of the box.
# This file is a reference for what each variable means.
# ============================================================

# ── Shared across all services ───────────────────────────────

# Secret used to sign and verify JWT tokens.
# MUST be changed to a long random string in any real deployment.
JWT_SECRET=super-secret-jwt-key-change-in-production

# ── User Service ─────────────────────────────────────────────
DATABASE_URL_USERS=postgresql+asyncpg://users_user:users_pass@localhost:5432/users_db
REDIS_URL_USERS=redis://localhost:6379/0

# ── Journey Service ──────────────────────────────────────────
DATABASE_URL_JOURNEYS=postgresql+asyncpg://journeys_user:journeys_pass@localhost:5432/journeys_db
REDIS_URL_JOURNEYS=redis://localhost:6379/1
# URL of the Conflict Detection Service (used during booking saga)
CONFLICT_SERVICE_URL=http://localhost:8003

# ── Conflict Detection Service ───────────────────────────────
DATABASE_URL_CONFLICTS=postgresql+asyncpg://conflicts_user:conflicts_pass@localhost:5432/conflicts_db
REDIS_URL_CONFLICTS=redis://localhost:6379/2

# ── Notification Service ─────────────────────────────────────
REDIS_URL_NOTIFICATIONS=redis://localhost:6379/3

# ── Enforcement Service ──────────────────────────────────────
# Reads active journey cache from the same Redis DB as Journey Service (DB 1)
REDIS_URL_ENFORCEMENT=redis://localhost:6379/1
# URL of the Journey Service (used as cache-miss fallback)
JOURNEY_SERVICE_URL=http://localhost:8002

# ── Analytics Service ────────────────────────────────────────
DATABASE_URL_ANALYTICS=postgresql+asyncpg://analytics_user:analytics_pass@localhost:5432/analytics_db
REDIS_URL_ANALYTICS=redis://localhost:6379/5

# ── RabbitMQ (shared by all services) ────────────────────────
RABBITMQ_URL=amqp://journey_admin:journey_pass@localhost:5672/journey_vhost

# ── PostgreSQL credentials (used in DB setup scripts) ────────
POSTGRES_USERS_USER=users_user
POSTGRES_USERS_PASS=users_pass
POSTGRES_JOURNEYS_USER=journeys_user
POSTGRES_JOURNEYS_PASS=journeys_pass
POSTGRES_CONFLICTS_USER=conflicts_user
POSTGRES_CONFLICTS_PASS=conflicts_pass
POSTGRES_ANALYTICS_USER=analytics_user
POSTGRES_ANALYTICS_PASS=analytics_pass

# ── RabbitMQ credentials ─────────────────────────────────────
RABBITMQ_USER=journey_admin
RABBITMQ_PASS=journey_pass
RABBITMQ_VHOST=journey_vhost
